<style>
  /* Dark mode via CSS filter — zero coupling to Avo internals */
  html.dark-mode {
    filter: invert(0.92) hue-rotate(180deg);
    background: #111;
  }
  html.dark-mode img,
  html.dark-mode video,
  html.dark-mode svg,
  html.dark-mode [style*="background-image"],
  html.dark-mode canvas,
  html.dark-mode .dark-mode-toggle {
    filter: invert(1) hue-rotate(180deg);
  }

  /* Dark mode toggle button */
  .dark-mode-toggle {
    position: fixed;
    top: 12px;
    right: 16px;
    z-index: 9999;
    background: rgba(255,255,255,0.9);
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 6px 10px;
    cursor: pointer;
    font-size: 18px;
    line-height: 1;
    transition: all 0.15s;
    backdrop-filter: blur(4px);
  }
  .dark-mode-toggle:hover {
    background: rgba(255,255,255,1);
    transform: scale(1.1);
  }

  /* Collapsible sidebar groups */
  .sidebar-group-items {
    overflow: hidden;
    transition: max-height 0.2s ease, opacity 0.2s ease;
    max-height: 500px;
    opacity: 1;
  }
  .sidebar-group.collapsed .sidebar-group-items {
    max-height: 0;
    opacity: 0;
  }
  .sidebar-chevron {
    transition: transform 0.2s ease;
  }
  .sidebar-group.collapsed .sidebar-chevron {
    transform: rotate(-90deg);
  }
</style>
<script>
  (function() {
    /* ── Dark mode ── */
    if (localStorage.getItem('avo_dark_mode') === 'true') {
      document.documentElement.classList.add('dark-mode');
    }

    function ensureDarkToggle() {
      if (document.querySelector('.dark-mode-toggle')) return;
      var btn = document.createElement('button');
      btn.className = 'dark-mode-toggle';
      btn.title = 'Toggle dark mode';
      btn.textContent = document.documentElement.classList.contains('dark-mode') ? '\u2600' : '\u263E';
      btn.addEventListener('click', function() {
        var on = document.documentElement.classList.toggle('dark-mode');
        localStorage.setItem('avo_dark_mode', on);
        btn.textContent = on ? '\u2600' : '\u263E';
      });
      document.body.appendChild(btn);
    }

    function syncDark() {
      var on = localStorage.getItem('avo_dark_mode') === 'true';
      document.documentElement.classList.toggle('dark-mode', on);
      var btn = document.querySelector('.dark-mode-toggle');
      if (btn) btn.textContent = on ? '\u2600' : '\u263E';
    }

    /* ── Collapsible sidebar groups ── */
    var STORAGE_KEY = 'avo_sidebar_collapsed';

    function getCollapsed() {
      try { return JSON.parse(localStorage.getItem(STORAGE_KEY)) || {}; } catch(e) { return {}; }
    }

    window.avoToggleGroup = function(key) {
      var el = document.querySelector('[data-group-key="' + key + '"]');
      if (!el) return;
      el.classList.toggle('collapsed');
      var state = getCollapsed();
      state[key] = el.classList.contains('collapsed');
      localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
    };

    function applySidebarState() {
      var state = getCollapsed();
      Object.keys(state).forEach(function(key) {
        if (!state[key]) return;
        var el = document.querySelector('[data-group-key="' + key + '"]');
        if (el) el.classList.add('collapsed');
      });
    }

    /* ── Init ── */
    document.addEventListener('DOMContentLoaded', function() {
      ensureDarkToggle();
      applySidebarState();
    });
    document.addEventListener('turbo:load', function() {
      syncDark();
      ensureDarkToggle();
      applySidebarState();
    });
  })();
</script>
