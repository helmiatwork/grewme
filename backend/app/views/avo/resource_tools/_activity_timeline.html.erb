<div class="flex flex-col">
  <%= render Avo::PanelComponent.new(name: "Activity Timeline") do |c| %>
    <% c.with_body do %>
      <div class="flex flex-col divide-y divide-gray-100">
        <%
          activities = PublicActivity::Activity
            .where(trackable: @resource.record)
            .order(created_at: :desc)
            .limit(25)
        %>

        <% if activities.any? %>
          <% activities.each do |activity| %>
            <div class="flex items-start gap-3 px-4 py-3 hover:bg-gray-50 transition-colors">
              <div class="flex-shrink-0 mt-1">
                <% case activity.key.split('.').last %>
                <% when 'create' %>
                  <div class="w-7 h-7 rounded-full bg-green-100 flex items-center justify-center">
                    <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                    </svg>
                  </div>
                <% when 'update' %>
                  <div class="w-7 h-7 rounded-full bg-blue-100 flex items-center justify-center">
                    <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                  </div>
                <% when 'destroy' %>
                  <div class="w-7 h-7 rounded-full bg-red-100 flex items-center justify-center">
                    <svg class="w-4 h-4 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                  </div>
                <% else %>
                  <div class="w-7 h-7 rounded-full bg-gray-100 flex items-center justify-center">
                    <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                  </div>
                <% end %>
              </div>

              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2">
                  <span class="text-sm font-medium text-gray-900">
                    <%= activity.key.split('.').last.capitalize %>d
                  </span>
                  <% if activity.owner.present? %>
                    <span class="text-xs text-gray-500">
                      by <%= activity.owner.try(:name) || activity.owner.try(:email) || "#{activity.owner_type} ##{activity.owner_id}" %>
                    </span>
                  <% end %>
                </div>

                <% if activity.parameters.present? && activity.parameters.any? %>
                  <div class="mt-1">
                    <% changes = activity.parameters %>
                    <% if changes.is_a?(Hash) && changes.any? %>
                      <div class="text-xs text-gray-500 space-y-0.5">
                        <% changes.each do |key, value| %>
                          <div>
                            <span class="font-medium"><%= key %></span>:
                            <span class="text-gray-600"><%= value.is_a?(Array) ? "#{value.first} → #{value.last}" : value %></span>
                          </div>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                <% end %>

                <div class="mt-1 text-xs text-gray-400">
                  <%= time_ago_in_words(activity.created_at) %> ago
                </div>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="px-4 py-8 text-center text-sm text-gray-400">
            No activity recorded yet
          </div>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>
