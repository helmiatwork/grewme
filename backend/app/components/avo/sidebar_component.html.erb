<%= content_tag :div,
  class: class_names(
    "avo-sidebar fixed z-[60] t-0 application-sidebar w-64 flex-1 border-r lg:border-none bg-none xh-dvh h-[calc(100dvh-4rem)] bg-application lg:bg-transparent",
    "print:hidden": Avo.configuration.hide_layout_when_printing,
    "hidden": !@sidebar_open,
  ),
  data: {
    sidebar_target: stimulus_target
  } do %>
  <div class="flex flex-col w-full h-full">
    <div class="flex-1 flex flex-col justify-between overflow-auto h-full pt-3 mac-styled-scrollbar">
      <div class="space-y-1 mb-4">
        <%= render Avo::Sidebar::LinkComponent.new label: 'Get started', path: helpers.avo.root_path, active: :exclusive if Rails.env.development? && Avo.configuration.home_path.nil? %>
        <% res_map = resources.index_by { |r| r.model_class.name } %>
        <% link_for = ->(model_name) {
          r = res_map[model_name]
          r ? render(Avo::Sidebar::LinkComponent.new(label: r.navigation_label, path: helpers.resources_path(resource: r))) : nil
        } %>
        <% groups = [
          { key: "school",     label: "School",     icon: "heroicons/outline/building-office-2",       items: %w[School Classroom ClassroomTeacher ClassroomStudent ClassroomEvent] },
          { key: "users",      label: "Users",      icon: "heroicons/outline/users",                   items: %w[Teacher Parent SchoolManager Student ParentStudent] },
          { key: "curriculum", label: "Curriculum", icon: "heroicons/outline/academic-cap",             items: %w[Subject Topic LearningObjective AcademicYear GradeCurriculum GradeCurriculumItem] },
          { key: "exams",      label: "Exams",      icon: "heroicons/outline/clipboard-document-check", items: %w[Exam ExamQuestion ClassroomExam ExamSubmission ExamAnswer RubricCriteria RubricScore ObjectiveMastery] },
          { key: "feed",       label: "Feed",       icon: "heroicons/outline/newspaper",               items: %w[FeedPost FeedPostStudent FeedPostLike FeedPostComment] },
          { key: "messaging",  label: "Messaging",  icon: "heroicons/outline/chat-bubble-left-right",  items: %w[Conversation Message GroupConversation GroupMessage Notification] },
          { key: "system",     label: "System",     icon: "heroicons/outline/cog-6-tooth",             items: %w[DailyScore Permission PushDevice RefreshToken PublicActivity::Activity] },
        ] %>
        <% groups.each do |g| %>
          <div class="sidebar-group" data-group-key="<%= g[:key] %>">
            <div class="sidebar-group-heading flex justify-between items-center cursor-pointer px-4 pr-3 py-1.5 text-gray-500 hover:text-gray-700 select-none"
                 onclick="window.avoToggleGroup('<%= g[:key] %>')">
              <div class="flex items-center text-xs uppercase font-semibold leading-none space-x-1">
                <span class="min-w-[20px]"><%= helpers.svg(g[:icon], class: 'h-4') %></span>
                <span><%= g[:label] %></span>
              </div>
              <svg class="sidebar-chevron h-4 w-4 transition-transform duration-150" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/>
              </svg>
            </div>
            <div class="sidebar-group-items w-full space-y-0.5">
              <% g[:items].each do |model_name| %>
                <%= link_for.(model_name) %>
              <% end %>
            </div>
          </div>
        <% end %>
        <%= render partial: "/avo/partials/sidebar_extra" %>
      </div>
    </div>
    <% if Rails.env.development? %>
      <div class="p-4 border-t group">
        <%= link_to helpers.avo.avo_private_status_path, class: "block px-4 py-2 border rounded flex justify-between items-center w-full text-black text-sm" do %>
          <span>Avo Status</span> <span>
            <div class="rounded-full w-4 h-4 <%= Avo.app_status ? "bg-green-400" : "bg-orange-400" %>"></div>
          </span>
        <% end %>
        <div class="absolute text-xs text-gray-700 group-hover:block hidden text-center w-full -ml-4">Visible only in development</div>
      </div>
    <% end %>
    <%= render Avo::SidebarProfileComponent.new user: helpers._current_user %>
  </div>
<% end %>
