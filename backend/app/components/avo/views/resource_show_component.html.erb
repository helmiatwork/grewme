<%= content_tag :div,
  data: {
    model_name: @resource.model_name.to_s,
    resource_name: @resource.class.to_s,
    record_id: @resource.record_param,
    selected_resources_name: @resource.model_key,
    selected_resources: [@resource.record_param],
    **@resource.stimulus_data_attributes
  } do %>

  <div class="flex gap-6 items-start">
    <%# Left: Resource data (80%) %>
    <div class="flex-1 min-w-0" style="flex-basis: 80%;">
      <%= content_tag :div, class: 'space-y-12' do %>
        <%= render_cards_component %>
        <% @resource.get_items.each_with_index do |item, index| %>
          <%= render Avo::Items::SwitcherComponent.new(
            resource: @resource,
            reflection: @reflection,
            item: item,
            index: index + 1,
            view: @view,
            parent_resource: @parent_resource,
            parent_record: @parent_record,
            parent_component: self,
            actions: @actions
          )%>
        <% end %>
      <% end %>
    </div>

    <%# Right: Activity timeline (20%) %>
    <div class="flex-shrink-0 hidden lg:block" style="flex-basis: 20%; min-width: 280px;">
      <div class="sticky top-4">
        <%
          activities = PublicActivity::Activity
            .where(trackable: @resource.record)
            .order(created_at: :desc)
            .limit(25)
        %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
          <div class="px-4 py-3 border-b border-gray-100 bg-gray-50">
            <h3 class="text-sm font-semibold text-gray-700">Activity Timeline</h3>
          </div>

          <div class="divide-y divide-gray-100 max-h-[calc(100vh-12rem)] overflow-y-auto">
            <% if activities.any? %>
              <% activities.each do |activity| %>
                <div class="flex items-start gap-2.5 px-3 py-2.5 hover:bg-gray-50 transition-colors">
                  <div class="flex-shrink-0 mt-0.5">
                    <% action_name = activity.key.to_s.split('.').last %>
                    <% if action_name == 'create' %>
                      <div class="w-6 h-6 rounded-full bg-green-100 flex items-center justify-center">
                        <svg class="w-3.5 h-3.5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                        </svg>
                      </div>
                    <% elsif action_name == 'update' %>
                      <div class="w-6 h-6 rounded-full bg-blue-100 flex items-center justify-center">
                        <svg class="w-3.5 h-3.5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                        </svg>
                      </div>
                    <% elsif action_name == 'destroy' %>
                      <div class="w-6 h-6 rounded-full bg-red-100 flex items-center justify-center">
                        <svg class="w-3.5 h-3.5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                        </svg>
                      </div>
                    <% else %>
                      <div class="w-6 h-6 rounded-full bg-gray-100 flex items-center justify-center">
                        <svg class="w-3.5 h-3.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                      </div>
                    <% end %>
                  </div>

                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-1.5">
                      <span class="text-xs font-medium text-gray-900 capitalize"><%= action_name %></span>
                      <% if activity.owner.present? %>
                        <span class="text-xs text-gray-400">
                          by <%= activity.owner.try(:name) || activity.owner.try(:email) || "#{activity.owner_type} ##{activity.owner_id}" %>
                        </span>
                      <% end %>
                    </div>

                    <% if activity.parameters.present? && activity.parameters.is_a?(Hash) && activity.parameters.any? %>
                      <div class="mt-0.5 text-xs text-gray-500 truncate">
                        <% activity.parameters.first(3).each do |key, value| %>
                          <span class="font-medium"><%= key %></span>: <%= value.is_a?(Array) ? "#{value.first} → #{value.last}" : value.to_s.truncate(30) %>
                        <% end %>
                      </div>
                    <% end %>

                    <div class="mt-0.5 text-xs text-gray-400">
                      <%= time_ago_in_words(activity.created_at) %> ago
                    </div>
                  </div>
                </div>
              <% end %>
            <% else %>
              <div class="px-4 py-8 text-center text-xs text-gray-400">
                No activity recorded yet
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <% if should_display_invalid_fields_errors? %>
    <turbo-stream action="append" target="alerts">
      <template>
        <% @resource.invalid_fields.each do |error| %>
          <%= render Avo::AlertComponent.new error[:alert_type], error[:message] %>
        <% end %>
      </template>
    </turbo-stream>
  <% end %>
<% end %>
